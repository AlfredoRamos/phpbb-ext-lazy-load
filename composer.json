{
	"name": "alfredoramos/lazyload",
	"type": "phpbb-extension",
	"description": "Lazy Load extension for phpBB",
	"homepage": "https://github.com/AlfredoRamos/phpbb-ext-lazy-load",
	"version": "0.3.0-beta",
	"time": "2019-01-20",
	"keywords": [
		"phpbb",
		"extension",
		"lazy-load"
	],
	"license": "GPL-2.0-only",
	"authors": [
		{
			"name": "Alfredo Ramos",
			"email": "alfredo.ramos@proton.me",
			"homepage": "https://alfredoramos.mx",
			"role": "Lead Developer"
		}
	],
	"require": {
		"php": "^8.1.0",
		"composer/installers": "^2.2.0"
	},
	"require-dev": {
		"phing/phing": "^3.1.2",
		"pear/archive_tar": "^1.6.0"
	},
	"extra": {
		"display-name": "Lazy Load",
		"soft-require": {
			"phpbb/phpbb": "~3.3.0"
		},
		"version-check": {
			"host": "alfredoramos.mx",
			"directory": "/phpbb-extensions/versions",
			"filename": "lazy-load.json",
			"ssl": true
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	}
}